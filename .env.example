# Copy to .env.local and fill in your Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
# Server-only — required for private signed-agreement PDF uploads and portal links
# Supabase → Project Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional — enables automatic headquarters_profile table creation on server
# Supabase → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=

NEXT_PUBLIC_SUPABASE_ENABLED=false
NEXT_PUBLIC_PERSISTENCE_BACKEND=session

# Headquarters Supabase Auth (server-only)
# Dedicated random value of at least 32 characters; never reuse another secret.
HQ_AUTH_LIMITER_SECRET=
# Set to 1 only after the deployment's edge/global POST /auth/hq/request
# abuse control has been configured and proven per the PR1a runbook.
HQ_AUTH_EDGE_RATE_LIMIT_VERIFIED=0
# Emergency rollback switch. 1 returns 503 before all PR1a protected routes.
HQ_AUTH_EMERGENCY_DISABLED=0

# Membership unlock timing for first-time activation: full (~11s) or fast (~5.6s)
# Returning members skip the ceremony automatically unless they choose replay.
NEXT_PUBLIC_UNLOCK_TIMING=full

# Legacy inner PIN for remaining non-Care Operations HQ/setup/experience flows.
# It never grants the Supabase-authenticated /hq outer boundary or Care Ops APIs.
# If unset, only that legacy inner gate may use private-beta behavior; /hq still
# requires an active hq_admin_users session.
NEXT_PUBLIC_ADMIN_PIN=

# Google Reviews (server-only — never use NEXT_PUBLIC)
# Places API Place Details for live rating, review count, and review preview.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=

# Google Business OAuth (server-only) — powers "Use my Google Business" in setup wizard
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override (defaults to https://YOUR_DOMAIN/api/admin/google-reviews/oauth/callback)
# GOOGLE_OAUTH_REDIRECT_URI=

# Jobber OAuth — server-only, read-only Care Operations connection
# Enter the callback shown in Headquarters into the Jobber draft app exactly.
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_TOKEN_ENCRYPTION_KEY=
# Required in production, for example:
# JOBBER_OAUTH_REDIRECT_URI=https://your-production-domain.com/api/admin/care-operations/jobber/oauth/callback
# Pin deliberately; update only after testing a newer active Jobber API version.
JOBBER_GRAPHQL_VERSION=2025-04-16

# Member Intelligence — AI Quote Engine (server-only)
OPENAI_API_KEY=
# OPENAI_QUOTE_MODEL=gpt-4o

# Digital Agreement System (server-only — required in Vercel for customer emails)
# RESEND_API_KEY=re_...
# Verified domain sender, e.g. HomeAtlas <agreements@yourdomain.com>
# RESEND_AGREEMENT_FROM=SqueegeeKing <agreements@squeegeeking.net>
# Comma-separated — notified on every /request lead submission
# LEAD_NOTIFY_EMAIL=noah@squeegeeking.net,dasan@squeegeeking.net

# Stripe card-on-file (SetupIntent + Elements)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...

# Founding member cohort — unset = all new memberships are founding until you set an end date
# FOUNDING_PERIOD_END=2026-12-31T23:59:59.999Z

# Public app URL for customer emails and portal magic links
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com
