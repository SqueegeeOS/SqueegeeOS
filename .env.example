# Copy to .env.local and fill in your Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional — enables automatic headquarters_profile table creation on server
# Supabase → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=

NEXT_PUBLIC_SUPABASE_ENABLED=false
NEXT_PUBLIC_PERSISTENCE_BACKEND=session

# Membership unlock timing for first-time activation: full (~11s) or fast (~5.6s)
# Returning members skip the ceremony automatically unless they choose replay.
NEXT_PUBLIC_UNLOCK_TIMING=full

# Headquarters PIN — required to enter /hq (8-hour browser session)
# Set in .env.local locally and in Vercel Environment Variables for production.
# If unset, /hq runs in private beta mode without a PIN requirement.
NEXT_PUBLIC_ADMIN_PIN=

# Google Reviews (server-only — never use NEXT_PUBLIC)
# Places API Place Details for live rating, review count, and review preview.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=

# Google Business OAuth (server-only) — powers "Use my Google Business" in setup wizard
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override (defaults to https://YOUR_DOMAIN/api/admin/google-reviews/oauth/callback)
# GOOGLE_OAUTH_REDIRECT_URI=

# Member Intelligence — AI Quote Engine (server-only)
OPENAI_API_KEY=
# OPENAI_QUOTE_MODEL=gpt-4o

# Digital Agreement System (server-only)
# RESEND_API_KEY=
# RESEND_AGREEMENT_FROM=HomeAtlas <agreements@homeatlas.com>
